POSTGRES_USER=database_user_here
POSTGRES_PASSWORD=your_postgres_password_here
POSTGRES_DB=smart_cv
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
LLM_PROVIDER=gemini

# If backend runs inside Docker (recommended with compose)
DATABASE_URL=postgresql+psycopg://username:password@postgres:5432/smart_cv

# If backend runs on your host machine (not inside Docker)
# DATABASE_URL=postgresql+psycopg://username:password@localhost:5432/smart_cv
